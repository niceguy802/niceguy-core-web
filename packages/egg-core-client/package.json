{
  "name": "@sisin/egg-core-client",
  "version": "1.1.1",
  "description": "Egg.js core framework — 封装数据层、认证、日志、Redis 等基础设施",
  "egg": {
    "framework": true
  },
  "scripts": {
    "test": "egg-bin test",
    "cov": "egg-bin cov",
    "pkgfiles": "egg-bin pkgfiles",
    "ci": "npm run pkgfiles -- --check && npm run cov",
    "prepublishOnly": "npm run ci",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish",
    "postversion": "git push --follow-tags"
  },
  "files": [
    "app",
    "config",
    "lib",
    "init",
    "app.js",
    "index.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/niceguy802/niceguy-core-web.git",
    "directory": "packages/egg-core-client"
  },
  "bugs": {
    "url": "https://github.com/niceguy802/niceguy-core-web/issues"
  },
  "homepage": "https://github.com/niceguy802/niceguy-core-web#readme",
  "keywords": [
    "egg",
    "egg-framework",
    "egg-core-client",
    "sisin"
  ],
  "author": "sisin",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "egg": "^3.30.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@niceguy/egg-core-client": "^1.0.9",
    "bcryptjs": "^3.0.3",
    "egg-scripts": "2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "autod": "^3",
    "autod-egg": "^1",
    "egg-bin": "^4",
    "egg-mock": "^4"
  }
}
