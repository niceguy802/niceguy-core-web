{
  "name": "@niceguy/egg-client",
  "version": "1.0.1",
  "description": "Egg.js 核心框架包 — 封装通用中间件、数据层、认证、日志、Redis 等基础设施",
  "main": "index.js",
  "files": [
    "index.js",
    "app.js",
    "app/",
    "config/",
    "init/"
  ],
  "egg": {
    "framework": true
  },
  "scripts": {
    "test": "egg-bin test",
    "test:unit": "mocha test/unit/*.test.js test/unit/**/*.test.js --timeout 10000",
    "test:cov": "egg-bin cov",
    "prisma:pull": "npx prisma db pull --config prisma.%npm_config_key%.config.ts",
    "prisma:generate": "npx prisma generate --config prisma.%npm_config_key%.config.ts",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish"
  },
  "keywords": [
    "egg",
    "egg-framework",
    "egg-client",
    "niceguy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/niceguy802/niceguy-core-web.git",
    "directory": "packages/egg-client"
  },
  "author": "niceguy",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  },
  "peerDependencies": {
    "egg": ">=3.0.0"
  },
  "devDependencies": {
    "egg": "^3.17.5",
    "egg-bin": "^6",
    "egg-mock": "^5",
    "mocha": "^10",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
