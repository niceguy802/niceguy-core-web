{
  "name": "@niceguy/nest-client",
  "version": "1.0.0",
  "description": "NestJS 核心框架包 — 封装通用中间件、数据层、认证、日志、Redis 等基础设施 (Egg.js Framework 能力迁移版)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "echo \"no test specified\" && exit 0"
  },
  "keywords": [
    "nestjs",
    "nest",
    "framework",
    "client",
    "niceguy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/niceguy802/niceguy-core-web.git",
    "directory": "packages/nest-client"
  },
  "author": "niceguy",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dayjs": "^1.11.20",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "@nestjs/jwt": ">=10.0.0",
    "@nestjs/passport": ">=10.0.0",
    "@nestjs/platform-express": ">=10.0.0",
    "passport": ">=0.7.0",
    "passport-jwt": ">=4.0.0",
    "reflect-metadata": ">=0.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
